# ===== صور Docker (يمكن تثبيت إصدار محدد بدل الافتراضي) =====
INFISICAL_IMAGE_TAG=latest
LITELLM_IMAGE_TAG=main-stable
PORTAINER_IMAGE_TAG=lts
POSTGRES_IMAGE_TAG=14-alpine
REDIS_IMAGE_TAG=7-alpine
DIND_IMAGE_TAG=27-dind
OPENHANDS_IMAGE_TAG=0.38

# ===== Postgres (قاعدة بيانات Infisical) =====
POSTGRES_USER=infisical
POSTGRES_PASSWORD=__يولّدها_install.sh__
POSTGRES_DB=infisical

# ===== Infisical — أسرار البنية (يولّدها install.sh تلقائياً) =====
ENCRYPTION_KEY=__يولّدها_install.sh__
AUTH_SECRET=__يولّدها_install.sh__
DB_CONNECTION_URI=postgres://infisical:__PASSWORD__@infisical-db:5432/infisical
REDIS_URL=redis://infisical-redis:6379
SITE_URL=http://localhost:8080
OTEL_TELEMETRY_COLLECTION_ENABLED=false

# ===== LiteLLM =====
LITELLM_MASTER_KEY=__يولّدها_install.sh__
WEBUI_SECRET_KEY=__يولّدها_install.sh__
OPEN_WEBUI_IMAGE_TAG=main
# مفاتيح النماذج تُدار عبر Infisical لاحقاً — اتركها فارغة الآن
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GITHUB_TOKEN=
GIT_USERNAME=
